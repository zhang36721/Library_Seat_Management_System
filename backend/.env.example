PROJECT_NAME=图书馆座位管理系统
API_V1_PREFIX=/api/v1
VERSION=1.0.0

# Cloud backend listens only on local loopback when behind Nginx.
HOST=127.0.0.1
PORT=18080
DEBUG=false

# For same-domain deployment, keep only your HTTPS origin.
# For quick debugging, you can temporarily set "*".
CORS_ORIGINS=https://www.kento.top
CORS_ALLOW_CREDENTIALS=false

SECRET_KEY=change-this-before-production
