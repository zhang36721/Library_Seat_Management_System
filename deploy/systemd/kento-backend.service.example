[Unit]
Description=Kento Library Seat Backend
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/library-seat
EnvironmentFile=/opt/library-seat/backend/.env
ExecStart=/opt/library-seat/.venv/bin/python -m uvicorn backend.main:app --host ${HOST} --port ${PORT}
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
