# Add these locations into the existing www.kento.top server block.
# Do not replace your current root/login project config.

location = /library-seat {
    return 301 /library-seat/;
}

location /library-seat/api/ {
    proxy_pass http://127.0.0.1:18080/api/;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
}

location = /library-seat/health {
    proxy_pass http://127.0.0.1:18080/health;
    proxy_set_header Host $host;
}

location /library-seat/ {
    alias /opt/library-seat/frontend/dist/;
    try_files $uri $uri/ /library-seat/index.html;
}

location = /library-seat/index.html {
    alias /opt/library-seat/frontend/dist/index.html;
}
